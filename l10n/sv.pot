msgid_plural "%n file conflicts in {dirname}"
msgstr[0] "%n filkonflikt i {dirname}"
msgstr[1] "%n filkonflikter i {dirname}"

msgid "All files"
msgstr "Alla filer"

msgid "Cancel"
msgstr "Avbryt"

