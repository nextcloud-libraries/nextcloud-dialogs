msgid "\"{char}\" is not allowed inside a folder name."
msgstr "\"{char}\" får inte ingå i ett mappnamn."

msgid "\"{char}\" is not allowed inside a name."
msgstr "\"{char}\" får inte ingå i ett namn."

msgid "\"{extension}\" is not an allowed name."
msgstr "\"{extension}\" får inte användas som namn."

msgid "\"{segment}\" is a reserved name and not allowed for folder names."
msgstr "\"{segment}\" är ett reserverat namn och får inte användas som mappnamn."

msgid "\"{segment}\" is a reserved name and not allowed."
msgstr "\"{segment}\" är ett reserverat namn och får inte användas."

