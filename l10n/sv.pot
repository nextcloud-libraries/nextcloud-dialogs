msgid_plural "Skip %n files"
msgstr[0] "Hoppa över %n fil"
msgstr[1] "Hoppa över %n filer"

msgid "Skip this file"
msgstr "Hoppa över den här filen"

msgid "Submit name"
msgstr "Bekräfta namnet"

msgid "Undo"
msgstr "Ångra"

